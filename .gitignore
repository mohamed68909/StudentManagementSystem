## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/ActiveWriter)
*.userprefs

# Mono auto generated files
*.pidb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bbin/
bin/
obj/
[Log]s/
[Ll]og/

# Visual Studio 2015/2017/2019/2022 cache directory or settings
.vs/

# MSTest test Results
[T]est[R]esults/
[Build]Source/

# OpenCover Test Coverage Results
*.xml

# NUnit
*.visualstate

# JetBrains Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# Rider OS metadata
.DS_Store
Thumbs.db